# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthcare_db

# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Admin
ADMIN_JWT_SECRET=your-super-secret-jwt-key-change-in-production
ADMIN_SESSION_SECRET=your-admin-session-secret

# Image Services
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-api-key
NEXT_PUBLIC_PEXELS_API_KEY=your-pexels-api-key
NEXT_PUBLIC_PIXABAY_API_KEY=your-pixabay-api-key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Environment
NODE_ENV=development
